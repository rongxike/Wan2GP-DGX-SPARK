prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: libavformat
Description: FFmpeg container format library
Version: 63.3.100
Requires: 
Requires.private: libavcodec >= 63.3.100, libswresample >= 7.2.100, libavutil >= 61.2.100
Conflicts:
Libs: -L${libdir}  -lavformat 
Cflags: -I${includedir}
