prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: libavfilter
Description: FFmpeg audio/video filtering library
Version: 12.2.100
Requires: 
Requires.private: libswscale >= 10.2.100, libavformat >= 63.3.100, libavcodec >= 63.3.100, libswresample >= 7.2.100, libavutil >= 61.2.100
Conflicts:
Libs: -L${libdir}  -lavfilter 
Cflags: -I${includedir}
